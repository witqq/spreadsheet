{
  "name": "@witqq/spreadsheet",
  "version": "0.3.0",
  "description": "Canvas-based spreadsheet engine \u2014 framework-agnostic core",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "sideEffects": false,
  "license": "BUSL-1.1",
  "author": "witqq contributors <belyiwork@mail.ru>",
  "keywords": [
    "spreadsheet",
    "datagrid",
    "canvas",
    "table",
    "grid",
    "excel",
    "typescript",
    "zero-dependencies",
    "editable-table",
    "data-grid",
    "canvas-rendering",
    "spreadsheet-engine"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/witqq/spreadsheet.git",
    "directory": "packages/core"
  },
  "homepage": "https://spreadsheet.witqq.dev",
  "bugs": {
    "url": "https://github.com/witqq/spreadsheet/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}