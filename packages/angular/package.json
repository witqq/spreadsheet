{
  "name": "@witqq/spreadsheet-angular",
  "version": "0.4.0",
  "description": "Angular wrapper for witqq Canvas spreadsheet engine",
  "keywords": [
    "spreadsheet",
    "datagrid",
    "canvas",
    "table",
    "grid",
    "excel",
    "typescript",
    "angular",
    "angular-table",
    "angular-spreadsheet"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@witqq/spreadsheet": "^0.4.0"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "@angular/common": ">=17.0.0"
  },
  "devDependencies": {
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "rxjs": "^7.8.0",
    "zone.js": "^0.15.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "typescript": "~5.6.0"
  },
  "sideEffects": false,
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/witqq/spreadsheet.git",
    "directory": "packages/angular"
  },
  "homepage": "https://spreadsheet.witqq.dev/frameworks/angular",
  "bugs": {
    "url": "https://github.com/witqq/spreadsheet/issues"
  },
  "author": "witqq team <belyiwork@mail.ru>"
}