<section class="pricing" id="pricing">
  <h2 class="section-title">Pricing</h2>
  <div class="pricing-grid">
    <div class="pricing-card">
      <h3>Non-Commercial</h3>
      <div class="pricing-price">Free</div>
      <ul class="pricing-features">
        <li>All features included</li>
        <li>Personal projects</li>
        <li>Education & research</li>
        <li>Open source (non-commercial)</li>
        <li>Community support</li>
      </ul>
      <a href="/getting-started/" class="btn btn-secondary">Get Started</a>
    </div>
    <div class="pricing-card highlighted">
      <span class="pricing-badge">Commercial</span>
      <h3>Commercial License</h3>
      <div class="pricing-price">Contact Us</div>
      <ul class="pricing-features">
        <li>All features included</li>
        <li>Production & commercial use</li>
        <li>Volume discounts available</li>
        <li>Priority support</li>
        <li>SLA available</li>
      </ul>
      <a href="mailto:belyiwork@mail.ru" class="btn btn-primary">Get License</a>
    </div>
  </div>
</section>
