{
  "name": "@witqq/spreadsheet-vue",
  "version": "0.2.0",
  "description": "Vue 3 wrapper for witqq Canvas spreadsheet engine",
  "keywords": [
    "spreadsheet",
    "datagrid",
    "canvas",
    "table",
    "grid",
    "excel",
    "typescript",
    "vue",
    "vue3",
    "vue-table",
    "vue-spreadsheet"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@witqq/spreadsheet": "*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "@vue/test-utils": "^2.4.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vue-tsc": "^2.0.0"
  },
  "sideEffects": false,
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/witqq/spreadsheet.git",
    "directory": "packages/vue"
  },
  "homepage": "https://spreadsheet.witqq.dev/frameworks/vue",
  "bugs": {
    "url": "https://github.com/witqq/spreadsheet/issues"
  },
  "author": "witqq team <belyiwork@mail.ru>"
}
