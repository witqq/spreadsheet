{
  "name": "@witqq/spreadsheet-react",
  "version": "0.4.1",
  "description": "React wrapper for witqq Canvas spreadsheet engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "docs:npm": "tsx ../../scripts/generate-npm-docs.ts --package react",
    "prepublishOnly": "npm run build && npm run docs:npm"
  },
  "dependencies": {
    "@witqq/spreadsheet": "^0.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "sideEffects": false,
  "license": "BUSL-1.1",
  "author": "witqq contributors <belyiwork@mail.ru>",
  "keywords": [
    "spreadsheet",
    "datagrid",
    "canvas",
    "table",
    "grid",
    "excel",
    "typescript",
    "react",
    "react-table",
    "react-spreadsheet",
    "react-datagrid"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/witqq/spreadsheet.git",
    "directory": "packages/react"
  },
  "homepage": "https://spreadsheet.witqq.dev",
  "bugs": {
    "url": "https://github.com/witqq/spreadsheet/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
