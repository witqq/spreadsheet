{
  "name": "@witqq/spreadsheet-plugins",
  "version": "0.4.0",
  "description": "Official plugins for witqq spreadsheet",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@witqq/spreadsheet": "^0.4.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "sideEffects": false,
  "license": "BUSL-1.1",
  "author": "witqq contributors <belyiwork@mail.ru>",
  "keywords": [
    "spreadsheet",
    "datagrid",
    "canvas",
    "plugins",
    "formula",
    "excel",
    "typescript",
    "collaboration",
    "conditional-formatting",
    "spreadsheet-plugins"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/witqq/spreadsheet.git",
    "directory": "packages/plugins"
  },
  "homepage": "https://spreadsheet.witqq.dev",
  "bugs": {
    "url": "https://github.com/witqq/spreadsheet/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}